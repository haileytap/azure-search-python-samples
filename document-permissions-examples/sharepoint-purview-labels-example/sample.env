# Foundry IQ (Azure AI Search)
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_KS_NAME=purview-sharepoint-ks
AZURE_SEARCH_KB_NAME=purview-sharepoint-kb

# Service principal — needs Azure AI Search Contributor and SharePoint app permissions
AZURE_CLIENT_ID=<your-app-client-id>
AZURE_CLIENT_SECRET=<your-app-client-secret>
AZURE_TENANT_ID=<your-tenant-id>

# SharePoint site to crawl
SHAREPOINT_SITE_URL=https://<your-tenant>.sharepoint.com/sites/<your-site>

# Azure OpenAI — used for embedding documents during SharePoint KS ingestion
AZURE_OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com/
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI or Foundry — used for answer synthesis in the knowledge base
AZURE_OPENAI_CHAT_ENDPOINT=https://<your-openai>.openai.azure.com/
AZURE_OPENAI_CHAT_API_KEY=<your-openai-api-key>
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_CHAT_MODEL=gpt-4o-mini
